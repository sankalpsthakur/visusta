{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://visusta.com/schemas/monthly-changelog.json",
  "title": "MonthlyChangelog",
  "description": "Technical changelog for monthly ESG regulatory tracking",
  "type": "object",
  "required": [
    "report_id",
    "reporting_period",
    "generated_at",
    "changes"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "description": "Unique identifier for this monthly report",
      "pattern": "^M-[0-9]{4}-[0-9]{2}$"
    },
    "reporting_period": {
      "type": "object",
      "required": ["year", "month"],
      "properties": {
        "year": { "type": "integer" },
        "month": { "type": "integer", "minimum": 1, "maximum": 12 },
        "month_name": { "type": "string" },
        "quarter": { "type": "integer", "minimum": 1, "maximum": 4 }
      }
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generated_by": {
      "type": "string",
      "description": "System or user that generated this report"
    },
    "report_metadata": {
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "schema_version": { "type": "string" },
        "previous_report_id": {
          "type": ["string", "null"],
          "description": "Reference to previous month's report"
        },
        "data_sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_changes": { "type": "integer" },
        "new_regulations": { "type": "integer" },
        "updated_regulations": { "type": "integer" },
        "unchanged_regulations": { "type": "integer" },
        "deprecated_regulations": { "type": "integer" },
        "by_topic": {
          "type": "object",
          "properties": {
            "GHG": { "type": "integer" },
            "Packaging": { "type": "integer" },
            "Water": { "type": "integer" },
            "Waste": { "type": "integer" },
            "Social/Human Rights": { "type": "integer" }
          }
        },
        "by_status": {
          "type": "object",
          "properties": {
            "Law Passed": { "type": "integer" },
            "Amendment in Progress": { "type": "integer" },
            "Change Under Discussion": { "type": "integer" }
          }
        },
        "by_jurisdiction": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "country_code": { "type": "string" },
              "count": { "type": "integer" }
            }
          }
        }
      }
    },
    "changes": {
      "type": "array",
      "items": {
        "$ref": "regulatory_change_schema.json"
      },
      "description": "Array of regulatory changes for this month"
    },
    "diff_summary": {
      "type": "object",
      "description": "Summary of changes since previous month",
      "properties": {
        "has_changes": { "type": "boolean" },
        "added_count": { "type": "integer" },
        "modified_count": { "type": "integer" },
        "removed_count": { "type": "integer" },
        "unchanged_count": { "type": "integer" },
        "highlights": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "change_id": { "type": "string" },
              "highlight_type": { "enum": ["Critical", "Major", "Trend" ] },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "audit_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string", "format": "date-time" },
          "action": {
            "enum": ["Created", "Modified", "Validated", "Published"]
          },
          "user": { "type": "string" },
          "details": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
